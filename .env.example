# Database (Turso / libSQL / local SQLite file)
DATABASE_URL="file:./packages/db/local.db"
DATABASE_AUTH_TOKEN=""

# 32-byte hex encryption key for AES-GCM-256
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Secrets
WORKER_SECRET="change-me-worker-secret"
EXECUTOR_API_KEY="change-me-executor-key"
CRON_SECRET="change-me-cron-secret"

# Public URL of the sync-worker (used for executor callbacks)
API_BASE_URL="http://localhost:8787"

# Dashboard API target
NEXT_PUBLIC_API_BASE_URL="http://localhost:8787"

# Dashboard origin (for CORS)
DASHBOARD_ORIGIN="http://localhost:3000"
